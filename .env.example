# ============================================================
# RAZONAPRO BACKEND — Variables de entorno
# Copia este archivo como .env y completa los valores
# NUNCA subas el .env real a git
# ============================================================

# ── Servidor ────────────────────────────────────────────────
SERVER_PORT=8080

# ── Base de datos (Supabase) ─────────────────────────────────
# Obtén la URL en: Supabase Dashboard → Settings → Database → Connection string → JDBC
# El ?currentSchema=razonapro fuerza el esquema por defecto
DB_URL=jdbc:postgresql://db.TU_PROJECT_REF.supabase.co:5432/postgres?currentSchema=razonapro
DB_USERNAME=postgres
DB_PASSWORD=tu_password_de_supabase

# ── JWT ──────────────────────────────────────────────────────
# Mínimo 256 bits (32 chars). Genera uno seguro:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_de_minimo_64_caracteres_muy_largo_y_aleatorio_xd
# 86400000 = 24 horas en ms
JWT_EXPIRATION_MS=86400000
# Token de verificación de email: 24h
JWT_EMAIL_VERIFY_EXPIRATION_MS=86400000

# ── Correo (Gmail SMTP) ───────────────────────────────────────
# Necesitas activar "App Passwords" en tu cuenta Google:
# myaccount.google.com → Security → 2-Step Verification → App passwords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu_correo@gmail.com
MAIL_PASSWORD=tu_app_password_de_16_digitos

# ── CORS ─────────────────────────────────────────────────────
# Orígenes permitidos separados por coma
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOWED_HEADERS=*
CORS_EXPOSED_HEADERS=Authorization
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=3600

# ── App ──────────────────────────────────────────────────────
# URL del frontend (para links en los emails)
FRONTEND_URL=http://localhost:3000

# ── Admin Initializer ─────────────────────────────────────────
# Se crea al levantar el servidor si no hay admins en la BD
ADMIN_INITIALIZER_ENABLED=true
ADMIN_INITIAL_EMAIL=admin@razonapro.com
ADMIN_INITIAL_PASSWORD=Admin123!
ADMIN_INITIAL_FIRST_NAME=Super
ADMIN_INITIAL_LAST_NAME=Admin
ADMIN_INITIAL_PHONE=+573001234567

# ── Logging / Debug ───────────────────────────────────────────
# En producción pon false a los dos
SHOW_SQL=true
FORMAT_SQL=true
